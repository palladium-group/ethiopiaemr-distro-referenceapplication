# Orthanc
ORTHANC_NAME=ETHIOPIAEMR PACS
ORTHANC_AET=ETHIOPIAEMR
ORTHANC_USERNAME=admin
ORTHANC_PASSWORD=Admin123
ORTHANC_DICOM_PORT=4242
ORTHANC_HTTP_PORT=8042
ORTHANC_URL=http://orthanc:8042

# OpenMRS / KenyaEMR
OPENMRS_URL=http://gateway/openmrs
OPENMRS_USERNAME=admin
OPENMRS_PASSWORD=Admin123

# The UUID of the KenyaEMR patient identifier type (e.g. OpenMRS ID or national ID)
# Find this at: http://<host>/openmrs/admin/patients/identifierTypes.list
OPENMRS_PATIENT_IDENTIFIER_TYPE_UUID=dfacd928-0370-4315-99d7-6ec1c9f7ae76 

# OpenMRS configuration
OPENMRS_URL=http://gateway/openmrs
# The application reads OPENMRS_USERNAME; keep OPENMRS_USER for backwards compatibility.
OPENMRS_USER=admin
OPENMRS_USERNAME=admin
OPENMRS_PASSWORD=Admin123
OPENMRS_RESULTS_ENCOUNTER_TYPE_UUID=
OPENMRS_IDENTIFIER_TYPE_UUID=dfacd928-0370-4315-99d7-6ec1c9f7ae76 
OPENMRS_CONCEPT_COMPLEX_UUID=

# Odoo configuration
ODOO_URL=host.docker.internal:8069
ODOO_USER=admin
ODOO_PASSWORD=admin
ODOO_DATABASE=odoo
EMR_WEIGHT_CONCEPT=
CREATE_CUSTOMER_IF_NOT_EXIST=false
ODOO_CUSTOMER_EXTERNAL_ID=comment
ODOO_CUSTOMER_DOB_FIELD=
ODOO_CUSTOMER_WEIGHT_FIELD=
ODOO_ENABLE_EXTRA_CUSTOMER_FIELDS_ROUTE=false
ODOO_ENABLE_EXTRA_QUOTATION_FIELDS_ROUTE=false

# Bahmni specific
BAHMNI_TEST_ORDER_TYPE_UUID=

# General EIP configuration
EIP_WATCHED_TABLES=patient,person_name,person_address,patient_identifier,orders,test_order,drug_order
DB_EVENT_DESTINATIONS_ODOO=direct:odoo-event-listener
EIP_DB_NAME_ODOO=openmrs_eip_mgt_odoo
EIP_DB_USER_ODOO=openmrs_eip_mgt_odoo
EIP_DB_PASSWORD_ODOO=password

# Orthanc EIP management database (Liquibase; same MySQL server as OpenMRS)
EIP_DB_NAME_ORTHANC=openmrs_eip_mgt_orthanc
EIP_DB_USER_ORTHANC=openmrs_eip_mgt_orthanc
EIP_DB_PASSWORD_ORTHANC=password

# OAuth2 Client (disabled; using Basic auth instead)
OAUTH_ENABLED=false
OAUTH_CLIENT_ID=eip
OAUTH_CLIENT_SECRET=_demo_sample_key_to_be_replaced_
OAUTH_CLIENT_SCOPE=email
OAUTH_ACCESS_TOKEN_URL=http://host.docker.internal:8080/openmrs/oauth/token

# FHIR configuration (required by camel-openmrs-fhir)
EIP_FHIR_RESOURCES=Patient,Encounter,Observation
EIP_FHIR_SERVER_URL=http://gateway/openmrs/ws/fhir2/R4
EIP_FHIR_USERNAME=admin
EIP_FHIR_PASSWORD=Admin123

# Orthanc
# - If Orthanc runs on your host machine: use host.docker.internal
# - If Orthanc runs as a docker-compose service: use http://orthanc:8042
ORTHANC_URL=http://host.docker.internal:8042
ORTHANC_USERNAME=admin
ORTHANC_PASSWORD=Admin123

# Debezium MySQL Connector (CDC) configuration
MYSQL_ADMIN_USER=debezium
MYSQL_ADMIN_USER_PASSWORD=debezium

# OpenMRS Datasource configuration
OPENMRS_DB_USER=root
OPENMRS_DB_PASSWORD=openmrs
OPENMRS_DB_NAME=openmrs
OPENMRS_DB_HOST=db
OPENMRS_DB_PORT=3306
ORTHANC_PUBLIC_URL=http://localhost:8042